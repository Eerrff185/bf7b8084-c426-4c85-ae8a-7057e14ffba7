name: Decompile DLL

on: [push]

jobs:
  decompile:
    runs-on: windows-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Setup .NET
        uses: actions/setup-dotnet@v3
        with:
          dotnet-version: '8.0.x'

      - name: Install ICSharpCode.Decompiler
        run: dotnet tool install --global ICSharpCode.Decompiler

      - name: Decompile DLL
        run: |
          # Substitua 'sua_biblioteca.dll' pelo nome do seu arquivo
          $dllPath = "AssemblyCSharp.dll"
          $outputPath = "decompiled_source"
          
          # Executa a descompilação
          icsharpcode.decompiler $dllPath -o $outputPath

      - name: Upload decompiled code
        uses: actions/upload-artifact@v3
        with:
          name: decompiled-source
          path: decompiled_source/
